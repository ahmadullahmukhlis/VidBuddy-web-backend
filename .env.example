# --- Application Setup ---
APP_NAME="VideoDownloader"
APP_ENV=local
APP_KEY=base64:0RZf8/uSdRPqeAQ/oLuXKdYJMuqlyLspzmAYc+CP1l4=
APP_DEBUG=true
APP_URL=http://localhost:8000


# --- NO DATABASE SETTINGS (Using File System) ---
# This prevents "Table not found" or "Connection refused" errors
SESSION_DRIVER=file
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_LIFETIME=120

# --- Frontend Connection (Next.js) ---
# Set this to your Next.js URL so CORS doesn't block requests
FRONTEND_URL=http://localhost:3000

# --- Ubuntu System Binary Paths ---
# Matches the paths from your README installation
YT_DLP_PATH=/usr/local/bin/yt-dlp
FFMPEG_PATH=/usr/bin/ffmpeg
FFPROBE_PATH=/usr/bin/ffprobe

# --- Logging ---
# Useful for debugging errors without a database
LOG_CHANNEL=stack
LOG_LEVEL=debug
